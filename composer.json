{
  "name": "useburrow/sdk-php",
  "version": "0.9.0",
  "description": "Burrow PHP SDK for plugin integrations.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Burrow\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Burrow\\Sdk\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
