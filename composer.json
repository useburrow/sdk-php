{
  "name": "useburrow/sdk-php",
  "version": "0.9.7",
  "description": "Burrow PHP SDK for plugin integrations.",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/useburrow/sdk-php",
  "keywords": [
    "burrow",
    "sdk",
    "php",
    "plugins",
    "events"
  ],
  "authors": [
    {
      "name": "Burrow",
      "homepage": "https://useburrow.com"
    }
  ],
  "support": {
    "issues": "https://github.com/useburrow/sdk-php/issues",
    "source": "https://github.com/useburrow/sdk-php"
  },
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Burrow\\Sdk\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Burrow\\Sdk\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
